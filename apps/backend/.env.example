COAI_ENVIRONMENT=local
COAI_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codebase_onboarding

# Repo storage
COAI_REPO_STORAGE_PATH=/tmp/coai/repos

# Optional: enable real LLM answers for /qa and /qa/stream
# IMPORTANT: never commit real keys. Use AWS Secrets Manager in production.
COAI_OPENAI_API_KEY=
COAI_OPENAI_MODEL=gpt-4.1-mini

# Optional: enable OpenAI embeddings for retrieval
COAI_EMBEDDINGS_PROVIDER=fake
COAI_OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

