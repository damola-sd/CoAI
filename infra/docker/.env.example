POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=codebase_onboarding
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000

COAI_ENVIRONMENT=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: enable real LLM answers for /qa
COAI_OPENAI_API_KEY=
COAI_OPENAI_MODEL=gpt-4.1-mini

# Optional: enable OpenAI embeddings for retrieval
COAI_EMBEDDINGS_PROVIDER=fake
COAI_OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

